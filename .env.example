# claude-mesh — example env file.
# Copy to .env (git-ignored) and tweak. The relay + `mesh` CLI auto-load
# .env.local first, then .env, from the current working directory.
# Pre-existing shell env vars always win.

# ─── Relay: node packages/relay/dist/index.js [init] ───
# Directory for the SQLite database, admin.token, and <handle>.paircode files.
MESH_DATA=./.mesh-data
# Port and bind address for the HTTP server.
PORT=8443
HOST=127.0.0.1

# ─── CLI: `mesh pair | admin | send | respond` ───
# Default relay URL so you don't need --relay on every invocation.
MESH_RELAY=http://127.0.0.1:8443

# Optional: if set, `mesh pair` uses this when no pair code is passed as an arg.
# MESH_PAIR_CODE=MESH-XXXX-XXXX-XXXX

# Optional: default --label value for `mesh pair` when --label is omitted.
# HOSTNAME=my-laptop
