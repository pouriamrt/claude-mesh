    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.2"
  }
}
